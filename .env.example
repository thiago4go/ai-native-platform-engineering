# Optional live Claude Code mode.
# Do not commit real keys.
ANTHROPIC_API_KEY=

# Optional model gateway endpoint for Claude Code.
# Leave unset for Claude Code's default Anthropic endpoint.
# Example: http://127.0.0.1:${YOUR_GATEWAY_PORT}
ANTHROPIC_BASE_URL=

# Optional route labels used by the standalone demo.
AI_MODEL_ROUTE_NAME=local-dev/claude-code-llm
AI_MODEL_BACKEND=local-dev/claude-haiku
